{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "him-case.schema.json",
  "title": "HIM Practice Case (Volume IV)",
  "type": "object",
  "required": [
    "id", "slug", "title", "volume", "chapter", "case_number", "order",
    "status", "difficulty", "importance", "deidentified",
    "verified", "references", "questions"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^CASE-MR-[0-9]{6}$" },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "title": { "type": "string", "minLength": 1 },
    "title_en": { "type": ["string", "null"] },
    "volume": { "type": "integer", "const": 4 },
    "chapter": { "type": "integer", "minimum": 1, "maximum": 15 },
    "case_number": { "type": "integer", "minimum": 1 },
    "order": { "type": "integer", "minimum": 1 },
    "status": {
      "type": "string",
      "enum": ["planned", "researching", "drafting", "reviewing", "verified", "published", "deprecated"]
    },
    "difficulty": { "type": "string", "enum": ["basic", "intermediate", "advanced"] },
    "importance": { "type": "string", "enum": ["A", "B", "C", "D"] },
    "exam_frequency": { "type": "string", "enum": ["high", "medium", "low", "unknown"] },
    "estimated_minutes": { "type": ["integer", "null"] },
    "deidentified": {
      "type": "boolean",
      "const": true,
      "description": "Must always be true. Cases must be synthetic or fully de-identified per PROJECT.md/CONTENT_MODEL.md §9."
    },
    "prerequisites": { "type": "array", "items": { "type": "string" } },
    "related_topics": { "type": "array", "items": { "type": "string" } },
    "tags": { "type": "array", "items": { "type": "string" } },
    "as_of_date": { "type": ["string", "null"] },
    "verified": { "type": "boolean" },
    "reviewers": { "type": "array" },
    "references": { "type": "array", "items": { "type": "string", "pattern": "^REF-" } },
    "questions": { "type": "array", "items": { "type": "string", "pattern": "^Q-" } }
  },
  "notes": "Body follows the 10-part structure defined in CURRICULUM.md for Volume IV chapters: 사례 개요, 원문 기록, 핵심 용어, 시간순 재구성, 진단 및 처치 추출, 기록 누락·모순 점검, 분류 또는 통계 적용, 법적·윤리적 고려, 연습문제, 상세 해설. All patient records are synthetic/de-identified — deidentified must be true."
}
