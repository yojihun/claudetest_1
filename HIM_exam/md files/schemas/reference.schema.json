{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "him-reference.schema.json",
  "title": "HIM Reference",
  "type": "object",
  "required": ["id", "type", "title", "status"],
  "properties": {
    "id": { "type": "string", "pattern": "^REF-" },
    "type": {
      "type": "string",
      "enum": [
        "exam_notice", "law", "regulation", "official_guideline",
        "classification", "standard", "statistics", "journal_article",
        "textbook", "professional_association", "secondary"
      ]
    },
    "title": { "type": "string", "minLength": 1 },
    "publisher": { "type": ["string", "null"] },
    "version": { "type": ["string", "null"] },
    "published_date": { "type": ["string", "null"] },
    "effective_date": { "type": ["string", "null"] },
    "accessed_date": { "type": ["string", "null"] },
    "url": { "type": ["string", "null"] },
    "document_number": { "type": ["string", "null"] },
    "language": { "type": ["string", "null"] },
    "status": { "type": "string", "enum": ["unverified", "located", "verified", "peer_reviewed", "deprecated", "active"] },
    "notes": { "type": ["string", "null"] }
  }
}
