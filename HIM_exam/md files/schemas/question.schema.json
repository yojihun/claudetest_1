{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "him-question.schema.json",
  "title": "HIM Question",
  "type": "object",
  "required": ["id", "status", "type", "topic_ids", "stem", "answer", "explanation", "verified"],
  "properties": {
    "id": { "type": "string", "pattern": "^Q-[A-Z]+-[0-9]{6}$" },
    "status": {
      "type": "string",
      "enum": ["planned", "drafting", "reviewing", "verified", "published", "deprecated"]
    },
    "type": {
      "type": "string",
      "enum": [
        "true_false", "multiple_choice", "multiple_select", "short_answer",
        "calculation", "matching", "ordering", "case_based",
        "record_interpretation", "coding", "flashcard"
      ]
    },
    "topic_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^HIM-V[0-9]+-C[0-9]+-S[0-9]+-T[0-9]+$" }
    },
    "subject_area": { "type": ["string", "null"] },
    "difficulty": { "type": "string", "enum": ["basic", "intermediate", "advanced"] },
    "cognitive_level": {
      "type": "string",
      "enum": ["remember", "understand", "apply", "analyze", "evaluate", "create"]
    },
    "importance": { "type": "string", "enum": ["A", "B", "C", "D"] },
    "stem": { "type": "string", "minLength": 1 },
    "options": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text"],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" }
        }
      }
    },
    "answer": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "explanation": { "type": "string", "minLength": 1 },
    "distractor_explanations": { "type": "object" },
    "references": { "type": "array", "items": { "type": "string", "pattern": "^REF-" } },
    "verified": { "type": "boolean" }
  },
  "notes": "For choice-type questions (true_false, multiple_choice, multiple_select), every value in answer must match an id in options, and options must be non-empty."
}
