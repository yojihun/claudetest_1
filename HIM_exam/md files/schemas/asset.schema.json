{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "him-asset.schema.json",
  "title": "HIM Asset",
  "type": "object",
  "required": ["id", "type", "title", "topic_ids", "file", "alt"],
  "properties": {
    "id": { "type": "string", "pattern": "^AST-" },
    "type": {
      "type": "string",
      "enum": ["flowchart", "comparison_table", "diagram", "timeline", "illustration", "icon", "decision_tree"]
    },
    "title": { "type": "string", "minLength": 1 },
    "topic_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^HIM-V[0-9]+-C[0-9]+-S[0-9]+-T[0-9]+$" }
    },
    "file": { "type": "string", "minLength": 1 },
    "alt": { "type": "string", "minLength": 1 },
    "caption": { "type": ["string", "null"] },
    "source": { "type": ["string", "null"] },
    "license": { "type": ["string", "null"] }
  }
}
