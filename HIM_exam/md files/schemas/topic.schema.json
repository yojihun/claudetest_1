{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "him-topic.schema.json",
  "title": "HIM Topic Frontmatter",
  "type": "object",
  "required": [
    "id", "slug", "title", "volume", "chapter", "section", "order",
    "status", "difficulty", "importance", "exam_frequency",
    "verified", "references", "questions"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^HIM-V[0-9]+-C[0-9]+-S[0-9]+-T[0-9]+$" },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "title": { "type": "string", "minLength": 1 },
    "title_en": { "type": ["string", "null"] },
    "volume": { "type": "integer", "minimum": 1, "maximum": 4 },
    "chapter": { "type": "integer", "minimum": 1 },
    "section": { "type": "integer", "minimum": 1 },
    "order": { "type": "integer", "minimum": 1 },
    "status": {
      "type": "string",
      "enum": ["planned", "researching", "drafting", "reviewing", "verified", "published", "deprecated"]
    },
    "difficulty": { "type": "string", "enum": ["basic", "intermediate", "advanced"] },
    "importance": { "type": "string", "enum": ["A", "B", "C", "D"] },
    "exam_frequency": { "type": "string", "enum": ["high", "medium", "low", "unknown"] },
    "estimated_minutes": { "type": ["integer", "null"], "minimum": 1 },
    "prerequisites": { "type": "array", "items": { "type": "string", "pattern": "^HIM-V[0-9]+-C[0-9]+-S[0-9]+-T[0-9]+$" } },
    "related_topics": { "type": "array", "items": { "type": "string", "pattern": "^HIM-V[0-9]+-C[0-9]+-S[0-9]+-T[0-9]+$" } },
    "tags": { "type": "array", "items": { "type": "string" } },
    "content_type": {
      "type": "array",
      "items": { "type": "string", "enum": ["concept", "comparison", "process", "formula", "law", "case"] }
    },
    "as_of_date": { "type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "verified": { "type": "boolean" },
    "reviewers": { "type": "array", "items": { "type": "string" } },
    "references": { "type": "array", "items": { "type": "string", "pattern": "^REF-" } },
    "assets": { "type": "array", "items": { "type": "string", "pattern": "^AST-" } },
    "questions": { "type": "array", "items": { "type": "string", "pattern": "^Q-" } }
  },
  "allowed_body_headings": [
    "학습목표", "한 문장 정의", "왜 중요한가", "선수 개념", "핵심 개념",
    "상세 설명", "비교표", "비교표 또는 흐름", "업무 흐름", "실무 사례",
    "국가시험 포인트", "자주 하는 실수", "관련 법령·표준", "AI Note",
    "핵심 요약", "플래시카드", "연습문제", "참고문헌"
  ]
}
